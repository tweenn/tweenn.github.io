{
	"name": "tweenn.github.io",
	"version": "1.0.0",
	"description": "Tweenn's homepage, card and about",
	"main": "src/index.js",
	"scripts": {
		"commit": "git cz",
		"build": "preact build",
		"serve": "sirv build --port 8080 --cors --single",
		"dev": "preact watch",
		"lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
		"test": "jest ./tests"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tweenn/tweenn.github.io.git"
	},
	"keywords": [
		"tweenn",
		"portfolio",
		"about"
	],
	"author": "Felipe Zuntini <felipezuntini@hotmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/tweenn/tweenn.github.io/issues"
	},
	"homepage": "https://github.com/tweenn/tweenn.github.io#readme",
	"devDependencies": {
		"@types/enzyme": "^3.10.5",
		"@types/jest": "^26.0.8",
		"@typescript-eslint/eslint-plugin": "^2.25.0",
		"@typescript-eslint/parser": "^2.25.0",
		"commitizen": "^4.2.4",
		"enzyme": "^3.11.0",
		"enzyme-adapter-preact-pure": "^3.1.0",
		"eslint": "^6.8.0",
		"eslint-config-preact": "^1.1.1",
		"git-cz": "^4.8.0",
		"jest": "^27.2.5",
		"jest-preset-preact": "^4.0.2",
		"preact-cli": "^3.0.0",
		"sirv-cli": "^1.0.0-next.3",
		"typescript": "^4.5.2"
	},
	"dependencies": {
		"preact": "^10.3.1",
		"preact-render-to-string": "^5.1.4",
		"preact-router": "^3.2.1"
	},
	"config": {
		"commitizen": {
			"path": "git-cz"
		}
	},
	"eslintConfig": {
		"parser": "@typescript-eslint/parser",
		"extends": [
			"preact",
			"plugin:@typescript-eslint/recommended"
		],
		"ignorePatterns": [
			"build/"
		]
	},
	"jest": {
		"preset": "jest-preset-preact",
		"setupFiles": [
			"<rootDir>/tests/__mocks__/browserMocks.ts",
			"<rootDir>/tests/__mocks__/setupTests.ts"
		]
	}
}
